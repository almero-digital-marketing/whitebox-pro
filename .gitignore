# ── Dependencies ──────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build output ──────────────────────────────────────────────
dist/
**/dist/
*.tgz

# ── Secrets / local config — NEVER commit ─────────────────────
# Real runtime config carries live DB / OpenAI / Mailgun / PBX secrets.
# Only the *.example template is tracked.
**/whitebox.config.js
# Test + runtime env files (Neon API key, etc). Only *.example is tracked.
.env
.env.*
!.env.example
!.env.test.example
*.pem
*.key
.npmrc

# ── External integrations — each lives in its own repo ────────
# Ad-network packages (meta/google/tiktok) and auth providers (auth0) are
# developed + released independently. Clone them into ./integrations and the
# `integrations/*` workspace glob links them locally; the monorepo tracks none
# of their source.
integrations/

# ── Legacy (kept on disk for reference, never in this repo) ────
whitebox-v1/

# ── Tooling noise ─────────────────────────────────────────────
.DS_Store
*.log
coverage/
.vitest/
.idea/
.vscode/
