# Copy to .env and fill in. .env is gitignored — never commit real values.
# Loaded automatically by `npm start` / `npm run dev` via --env-file.

WB_PORT="3000"

# Postgres (pgvector). Neon or any Postgres.
WB_DB_HOST="ep-xxxx.eu-central-1.aws.neon.tech"
WB_DB_PORT="5432"
WB_DB_NAME="neondb"
WB_DB_USER="neondb_owner"
WB_DB_PASSWORD=""

WB_REDIS_HOST="localhost"
WB_REDIS_PORT="6379"

WB_OPENAI_API_KEY="sk-..."

# Bearer tokens gating the plugin admin/analytics endpoints (generate random).
WB_ENGAGEMENT_TOKEN=""
WB_ANALYTICS_TOKEN=""

# VoIP (only needed if 'voip' is in plugins)
WB_PBX_HOST="pbx.example.com"
WB_PBX_USER="voip"
WB_PBX_PASSWORD=""
WB_MONITOR_USER="voip"
WB_MONITOR_PASSWORD=""
WB_GCLOUD_KEYFILE="/path/to/voip.keyfile.json"
