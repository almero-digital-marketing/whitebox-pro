{
  "name": "whitebox-pro-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Whitebox monorepo — server core, browser client, and channel plugins. Each workspace publishes as its own npm package.",
  "workspaces": [
    "whitebox-pro-server",
    "whitebox-pro-client",
    "whitebox-pro-adnetworks",
    "server-plugin-*",
    "client-plugin-*"
  ],
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "test:server": "npm test --workspace=whitebox-pro-server",
    "link:integrations": "bash scripts/link-integrations.sh",
    "postinstall": "bash scripts/link-integrations.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "vitest": "^2.1.9"
  }
}
